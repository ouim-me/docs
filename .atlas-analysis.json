  "keyFeatures": [
    "Prebuilt React components for authentication (AuthProvider, UserCenter, CallbackPage)",
    "useAuth hook for accessing user and auth actions with route protection",
    "Backend JWT verification with Express and Next.js middleware",
    "Guest mode support with fingerprinting",
    "Built-in bundler configuration for Vite, Webpack, and Next.js",
    "Full TypeScript support with comprehensive type definitions"
  ],

{
  "$schema": "https://mintlify.com/docs.json",
  "name": "ouim/docs",
  "theme": "maple",
  "favicon": "/logo.svg",
  "colors": {
    "primary": "#DA7756",
    "light": "#e08970",
    "dark": "#BD5D3A"
  },
  "contextual": {
    "options": ["copy", "claude", "grok", "mcp"]
  },

  "background": {
    "color": {
      "light": "#FAF9F5",

      "dark": "#1a1814"
    }
  },
  "fonts": {
    "heading": {
      "family": "Google Sans"
    },
    "body": {
      "family": "Google Sans"
    }
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/ouim-me"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/ouim-me"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Reacher",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["reacher/introduction", "reacher/quickstart", "reacher/connecting-to-claude"]
          },
          {
            "group": "Configuration",
            "pages": [
              "reacher/configuration/environment-variables",
              "reacher/configuration/reacher-config",
              "reacher/configuration/domain-allowlist"
            ]
          },
          {
            "group": "Tools",
            "pages": [
              "reacher/tools/overview",
              "reacher/tools/ssh-exec",
              "reacher/tools/tailscale-status",
              "reacher/tools/fetch-external",
              "reacher/tools/github-search",
              "reacher/tools/gist-kb",
              "reacher/tools/browser"
            ]
          },
          {
            "group": "Deployment",
            "pages": [
              "reacher/deployment/docker",
              "reacher/deployment/bare-node",
              "reacher/deployment/easypanel",
              "reacher/deployment/railway-render"
            ]
          },
          {
            "group": "Operations",
            "pages": [
              "reacher/operations/safety",
              "reacher/operations/audit-log",
              "reacher/operations/dry-run",
              "reacher/operations/troubleshooting"
            ]
          },
          {
            "group": "Extending",
            "pages": ["reacher/extending/adding-tools", "reacher/extending/token-injection"]
          }
        ]
      },
      {
        "tab": "logto-authkit",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["logto-authkit/introduction", "logto-authkit/installation", "logto-authkit/quickstart"]
          },
          {
            "group": "Frontend",
            "pages": [
              "logto-authkit/frontend/auth-provider",
              "logto-authkit/frontend/user-center",
              "logto-authkit/frontend/callback-page",
              "logto-authkit/frontend/use-auth",
              "logto-authkit/frontend/route-protection"
            ]
          },
          {
            "group": "Server",
            "pages": [
              "logto-authkit/server/overview",
              "logto-authkit/server/express-middleware",
              "logto-authkit/server/nextjs-integration",
              "logto-authkit/server/generic-usage"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "logto-authkit/configuration/bundler-setup",
              "logto-authkit/configuration/guest-mode",
              "logto-authkit/configuration/custom-navigation"
